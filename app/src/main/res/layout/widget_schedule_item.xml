<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/itemContentRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="18dp"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:layout_width="2dp"
                android:layout_height="8dp"
                android:background="@color/widget_timeline_track"
                android:text="" />

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_timeline_dot" />

            <TextView
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="@color/widget_timeline_track"
                android:text="" />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/widgetBubble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_card_bg_default"
            android:paddingHorizontal="11dp"
            android:paddingTop="9dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/itemTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:00 - 10:30"
                android:textColor="@color/widget_item_time"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/itemTime"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:text="ALG I"
                android:textColor="@color/widget_item_subject"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/itemSubject"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:text="Ing. Jan Novak"
                android:textColor="@color/widget_item_room"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/itemRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/itemTeacher"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:text="POREB425"
                android:textColor="@color/widget_item_room"
                android:textSize="11sp" />

        </RelativeLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/itemNowLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:background="@color/widget_timeline_line"
        android:text=""
        android:visibility="gone" />

</RelativeLayout>