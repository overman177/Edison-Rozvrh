<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/itemContentRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="54dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/itemStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textColor="@color/widget_item_time"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="22dp"
                android:layout_height="1dp"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"
                android:background="@color/widget_timeline_track"
                android:text="" />

            <TextView
                android:id="@+id/itemEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/widgetBubble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_card_bg_default"
            android:paddingStart="11dp"
            android:paddingTop="11dp"
            android:paddingEnd="12dp"
            android:paddingBottom="11dp">

            <TextView
                android:id="@+id/itemDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/itemRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="2dp"
                android:ellipsize="end"
                android:letterSpacing="0.03"
                android:maxLines="1"
                android:text="POREA425"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="10dp"
                android:layout_toEndOf="@id/itemDot"
                android:layout_toStartOf="@id/itemRoom"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="ALG I"
                android:textColor="@color/widget_item_subject"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemTeacher"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text=""
                android:visibility="gone" />

            <TextView
                android:id="@+id/itemTime"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text=""
                android:visibility="gone" />

        </RelativeLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/itemNowLine"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_alignParentTop="true"
        android:background="@color/widget_timeline_line"
        android:text=""
        android:visibility="gone" />

</RelativeLayout>
